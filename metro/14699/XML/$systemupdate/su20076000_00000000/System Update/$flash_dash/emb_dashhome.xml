                    </onclick>
                </slot>
            </slotgroup>

            <!-- Slot 2 -->
            <slotgroup>
                <slot>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Music</definitionpath>
                </slot>
            </slotgroup>

            <!-- Slot 3 -->
            <slotgroup>
                <slot>
                    <name>Music Marketplace</name>
                    <description>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_PRON)%</phrase>
                        <responsetype>RequestYesNo</responsetype>
                        <message>%EvResStr(IDS_CONTROLLER_REQUIRED_VUI_MESSAGE)%</message>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsPromo</path>
                        <param>common://ico_64x_Marketplace.png</param>
                    </deepasset>
                </slot>
            </slotgroup>
        </channeldef>
    </channel>

    <!-- APPS HUB -->
    <channel>
        <id>APPS</id>
        <channeldef layouttemplate="epix://template7.xur">
            <description>%EvResStr(IDS_CHANNEL_APPS_VUI_DISPLAY)%</description>
            <vui>
                <phrase>%EvResStr(IDS_CHANNEL_APPS_VUI_PRON)%</phrase>
            </vui>

            <!-- Slot 1 -->
            <slotgroup>
                <slot>
                    <name>Collection</name>
                    <description>%EvResStr(IDS_SLOT_APPS_COLLECTION_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_APPS_COLLECTION_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_APPS_COLLECTION_VUI_PRON)%</phrase>
