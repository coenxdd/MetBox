                    </deepasset>
                    <onclick>
                        <button>A</button>
                        <action>EpixCmd</action>
                        <cmd>EcNavToURI</cmd>
                        <param>applibrary:_LibraryType=apps;</param>
                    </onclick>
                </slot>
            </slotgroup>

            <!-- Slot 2 -->
            <slotgroup>
                <slot>
                    <condition>EcoInLiveLocale()</condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Apps</definitionpath>
                </slot>
                <slot>
                    <name>Apps Static</name>
                    <!-- Show a static slot for locales with no LIVE service -->
                    <metadata>
                        <property>
                            <name>Interactive</name>
                            <value>no</value>
                        </property>
                    </metadata>
                    <shallowimg>epix://appsbg.jpg</shallowimg>
                </slot>
            </slotgroup>

            <!-- Slot 3 -->
            <slotgroup>
                <slot>
                    <condition>EcoInLiveLocale()</condition>
                    <name>Apps Marketplace</name>
                    <description>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_PRON)%</phrase>
