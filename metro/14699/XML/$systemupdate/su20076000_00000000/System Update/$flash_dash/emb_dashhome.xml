<?xml version="1.0" encoding="utf-8"?>
<manifest>
    <id>nuihub</id>
    <defaultchannelid>HOME</defaultchannelid>

    <!-- HOME HUB -->
    <channel>
        <id>HOME</id>
        <channeldef layouttemplate="epix://template1.xur">
            <description>%EvResStr(IDS_CHANNEL_HOME_VUI_DISPLAY)%</description>
            <vui>
                <phrase>%EvResStr(IDS_CHANNEL_GO_HOME_VUI_PRON)%</phrase>
                <phrase>%EvResStr(IDS_CHANNEL_HOME_VUI_PRON)%</phrase>
            </vui>

            <!-- SLOT 1 -->
            <slotgroup>
                <slot>
                    <definitionpath>slot://DiscInTray</definitionpath>
                </slot>
            </slotgroup>

            <!-- SLOT 2 -->
            <slotgroup maxscenes="5" delay="4000">
                <slot>
                    <condition>EcoUserSignedIn(0)</condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Reconnect</definitionpath>
                </slot>
                <slot>
                    <condition>!EcoUserSignedIn(0)</condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Home1</definitionpath>
                </slot>
                <slot>
                    <condition>
                        <condition>!EcoUserSignedIn(0)</condition>
                        <condition>EcoVideoMarketplaceAvailable()</condition>
                    </condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Home2</definitionpath>
                </slot>
                <slot>
                    <condition>
                        <condition>!EcoUserSignedIn(0)</condition>
                        <condition>EcoInLiveLocale()</condition>
                    </condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Home3</definitionpath>
                </slot>
                <slot>
                    <condition>
                        <condition>!EcoUserSignedIn(0)</condition>
                        <condition>EcoMusicMarketplaceAvailable()</condition>
                    </condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Home4</definitionpath>
                </slot>
                <slot>
                    <condition>
                        <condition>!EcoUserSignedIn(0)</condition>
                        <condition>EcoInLiveLocale()</condition>
                    </condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Home5</definitionpath>
                </slot>
            </slotgroup>

            <!-- SLOT 3 -->
            <slotgroup>
                <slot>
                    <name>Xbox101</name>
                    <description>%EvResStr(IDS_SLOT_XBOX101_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_XBOX101_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_XBOX101_VUI_PRON)%</phrase>
                        <responsetype>ControllerRequired</responsetype>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsXbox101</path>
                    </deepasset>
                    <onclick>
                        <button>A</button>
                        <action>EpixCmd</action>
                        <cmd>EcNavToURI</cmd>
                        <param>firstuse</param>
                    </onclick>
                    <metadata>
                        <property>
                            <name>gradient</name>
                            <value>yes</value>
                        </property>
                    </metadata>
                </slot>
            </slotgroup>

            <!-- SLOT 4 -->
            <slotgroup>
                <slot>
                    <definitionpath>slot://builtin.contentapp.xzp</definitionpath>
                </slot>
            </slotgroup>

            <!-- Slot 5 -->
            <slotgroup>
                <slot>
                    <name>Network Troubleshooter</name>
                    <description>%EvResStr(IDS_SLOT_NETWORK_CHECK_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_NETWORK_CHECK_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_NETWORK_CHECK_VUI_PRON)%</phrase>
                        <responsetype>RequestYesNo</responsetype>
                        <message>%EvResStr(IDS_CONTROLLER_REQUIRED_VUI_MESSAGE)%</message>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsNetworkHelp</path>
                    </deepasset>
                    <onclick>
                        <button>A</button>
                        <action>EpixCmd</action>
                        <cmd>EcNavToURI</cmd>
                        <param>networkhelp</param>
                    </onclick>
                    <metadata>
                        <property>
                            <name>gradient</name>
                            <value>yes</value>
                        </property>
                    </metadata>
                </slot>
            </slotgroup>
        </channeldef>
    </channel>

    <!-- SOCIAL HUB -->
    <channel>
        <id>social</id>
        <definitionpath>channel://BuiltIn.Social.Lua.Offline.xzp</definitionpath>
    </channel>

    <!-- VIDEO HUB -->
    <channel>
        <id>VIDEO</id>
        <metadata>
            <property>
                <name>VuiContext</name>
                <value>video</value>
            </property>
        </metadata>
        <channeldef layouttemplate="epix://template7.xur">
            <condition>EcoVideoMarketplaceAvailable()</condition>
            <description>%EvResStr(IDS_CHANNEL_VIDEO_VUI_DISPLAY)%</description>
            <vui>
                <phrase>%EvResStr(IDS_CHANNEL_VIDEO_VUI_PRON)%</phrase>
            </vui>

            <!-- Slot 1  -->
            <slotgroup>
                <slot>
                    <name>Collection</name>
                    <description>%EvResStr(IDS_SLOT_VIDEO_COLLECTION_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_VIDEO_COLLECTION_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_VIDEO_COLLECTION_VUI_PRON)%</phrase>
                        <responsetype>SceneNavigate</responsetype>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsVideoLibrary</path>
                    </deepasset>
                    <onclick>
                        <button>A</button>
                        <action>EpixCmd</action>
                        <cmd>EcNavToURI</cmd>
                        <param>applibrary:Category=4;_LibraryType=video;</param>
                    </onclick>
                </slot>
            </slotgroup>

            <!-- Slot 2  -->
            <slotgroup>
                <slot>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Video</definitionpath>
                </slot>
            </slotgroup>

            <!-- Slot 3 -->
            <slotgroup>
                <slot>
                    <name>Video Marketplace</name>
                    <description>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_MARKETPLACE_VUI_PRON)%</phrase>
                        <responsetype>RequestYesNo</responsetype>
                        <message>%EvResStr(IDS_CONTROLLER_REQUIRED_VUI_MESSAGE)%</message>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsPromo</path>
                        <param>common://ico_64x_Marketplace.png</param>
                    </deepasset>
                </slot>
            </slotgroup>
        </channeldef>
    </channel>

    <!-- GAMES HUB -->
    <channel>
        <id>GAMES</id>
        <metadata>
            <property>
                <name>VuiContext</name>
                <value>game</value>
            </property>
        </metadata>
        <channeldef layouttemplate="epix://template7.xur">
            <description>%EvResStr(IDS_CHANNEL_GAMES_VUI_DISPLAY)%</description>
            <vui>
                <phrase>%EvResStr(IDS_CHANNEL_GAMES_VUI_PRON)%</phrase>
            </vui>

            <!-- Slot 1 -->
            <slotgroup>
                <slot>
                    <name>Collection</name>
                    <description>%EvResStr(IDS_SLOT_GAMES_COLLECTION_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_GAMES_COLLECTION_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_GAMES_COLLECTION_VUI_PRON)%</phrase>
                        <responsetype>SceneNavigate</responsetype>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsGameLibrary</path>
                    </deepasset>
                    <onclick>
                        <button>A</button>
                        <action>EpixCmd</action>
                        <cmd>EcNavToURI</cmd>
                        <param>gameslibrary:_RootTitle=%slot_description%;</param>
                    </onclick>
                </slot>
            </slotgroup>

            <!-- Slot 2 -->
            <slotgroup>
                <slot>
                    <condition>EcoInLiveLocale()</condition>
                    <definitionpath>slot://BuiltIn.OfflineUpsell.xzp/Games</definitionpath>
                </slot>
                <slot>
                    <name>Games Static</name>
                    <!-- Show a static slot for locales with no LIVE service -->
                    <metadata>
                        <property>
                            <name>Interactive</name>
                            <value>No</value>
                        </property>
                    </metadata>
                    <shallowimg>epix://gamesbg.jpg</shallowimg>
                </slot>
            </slotgroup>

            <!-- Slot 3 -->
            <slotgroup>
                <slot>
                    <condition>EcoInLiveLocale()</condition>
                    <name>Game Marketplace</name>
                    <description>%EvResStr(IDS_SLOT_GAMEMARKETPLACE_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_GAMEMARKETPLACE_VUI_DISPLAY_ALT)%</visiblephrase>
                        <phrase>%EvResStr(IDS_SLOT_GAMEMARKETPLACE_VUI_PRON)%</phrase>
                        <responsetype>RequestYesNo</responsetype>
                        <message>%EvResStr(IDS_CONTROLLER_REQUIRED_VUI_MESSAGE)%</message>
                    </vui>
                    <deepasset>
                        <format>EpixScene</format>
                        <path>EsPromo</path>
                        <param>common://ico_64x_Marketplace.png</param>
                    </deepasset>
                </slot>
                <slot>
                    <name>Games MP Static</name>
                    <!-- Show a static slot for locales with no LIVE service -->
                    <metadata>
                        <property>
                            <name>Interactive</name>
                            <value>No</value>
                        </property>
                    </metadata>
                    <shallowimg>epix://offline_mp.jpg</shallowimg>
                </slot>
            </slotgroup>
        </channeldef>
    </channel>

    <!-- MUSIC HUB -->
    <channel>

        <id>MUSIC</id>
        <metadata>
            <property>
                <name>VuiContext</name>
                <value>music</value>
            </property>
        </metadata>

        <channeldef layouttemplate="epix://template7.xur">
            <condition>EcoMusicMarketplaceAvailable()</condition>
            <description>%EvResStr(IDS_CHANNEL_MUSIC_VUI_DISPLAY)%</description>
            <vui>
                <phrase>%EvResStr(IDS_CHANNEL_MUSIC_VUI_PRON)%</phrase>
            </vui>

            <!-- Slot 1 -->
            <slotgroup>
                <slot>
                    <name>Collection</name>
                    <description>%EvResStr(IDS_SLOT_MUSIC_COLLECTION_VUI_DISPLAY)%</description>
                    <vui>
                        <visiblephrase>%EvResStr(IDS_SLOT_MUSIC_COLLECTION_VUI_DISPLAY_ALT)%</visiblephrase>
